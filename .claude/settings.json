{
  "language": "portuguese",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git commit*)",
      "Bash(git push origin*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git pull*)",
      "Bash(npm run*)",
      "Bash(npm install*)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls*)",
      "Bash(which*)",
      "Bash(mkdir*)",
      "Bash(cat *)",
      "Bash(sed *)",
      "Bash(wsl bash*)",
      "Bash(cd *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)"
    ]
  }
}
